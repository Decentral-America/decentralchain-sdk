{
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["test/ui.spec.ts", "test/utils/hooks.ts", "test/utils/actions.ts"],
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationDir": "./dist/types",
    "experimentalDecorators": true,
    "lib": ["esnext", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noErrorTruncation": true,
    "noImplicitAny": false,
    "outDir": "./dist",
    "pretty": true,
    "sourceMap": false,
    "strict": true,
    "target": "es6",
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "types": ["@decentralchain/cubensisconnect-types", "vitest/globals"]
  }
}
