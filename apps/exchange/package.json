{
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "build": {
    "appId": "com.decentralchain.exchange",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "category": "Finance",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "category": "public.app-category.finance",
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "productName": "DecentralExchange",
    "publish": {
      "owner": "decentralchain",
      "provider": "github",
      "repo": "dcc-exchange"
    },
    "win": {
      "certificateFile": null,
      "certificatePassword": null,
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "@decentralchain/assets-pairs-order": "workspace:*",
    "@decentralchain/bignumber": "workspace:*",
    "@decentralchain/browser-bus": "workspace:*",
    "@decentralchain/data-entities": "workspace:*",
    "@decentralchain/data-service-client-js": "workspace:*",
    "@decentralchain/oracle-data": "workspace:*",
    "@decentralchain/signature-adapter": "workspace:*",
    "@decentralchain/transactions": "workspace:*",
    "@decentralchain/ts-lib-crypto": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@sentry/react": "^10.43.0",
    "@tanstack/react-query": "^5.90.21",
    "bignumber.js": "^10.0.2",
    "cryptocurrency-icons": "^0.18.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.8.18",
    "qrcode.react": "^4.2.0",
    "ramda": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga4": "^2.1.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11",
    "ts-utils": "^6.1.0",
    "victory": "^37.3.6",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "catalog:",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "jsdom": "catalog:",
    "vite": "^8.0.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/apps/exchange",
  "main": "electron/main.js",
  "name": "exchange",
  "nx": {
    "tags": [
      "scope:app",
      "layer:5"
    ]
  },
  "private": true,
  "repository": {
    "directory": "apps/exchange",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "electron:build": "tsc -p electron && electron-builder",
    "electron:build:linux": "tsc -p electron && electron-builder --linux",
    "electron:build:mac": "tsc -p electron && electron-builder --mac",
    "electron:build:win": "tsc -p electron && electron-builder --win",
    "electron:dev": "tsc -p electron && NODE_ENV=development electron .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "merge-locales": "node scripts/mergeLocales.js",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit"
  },
  "type": "module",
  "version": "1.0.0"
}
