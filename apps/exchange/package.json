{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/exchange/issues"
  },
  "build": {
    "appId": "com.decentralchain.wallet",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "category": "Finance",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "category": "public.app-category.finance",
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "productName": "DCC Wallet",
    "publish": {
      "owner": "decentralchain",
      "provider": "github",
      "repo": "dcc-wallet"
    },
    "win": {
      "certificateFile": null,
      "certificatePassword": null,
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "@decentralchain/assets-pairs-order": "^5.0.2",
    "@decentralchain/bignumber": "^1.2.1",
    "@decentralchain/browser-bus": "^1.0.1",
    "@decentralchain/data-entities": "^3.0.1",
    "@decentralchain/data-service-client-js": "^4.2.1",
    "@decentralchain/oracle-data": "^1.0.1",
    "@decentralchain/signature-adapter": "^7.0.1",
    "@decentralchain/ts-lib-crypto": "^2.0.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@sentry/react": "^10.43.0",
    "@tanstack/react-query": "^5.90.21",
    "bignumber.js": "^10.0.2",
    "cryptocurrency-icons": "^0.18.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.8.18",
    "qrcode.react": "^4.2.0",
    "ramda": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga4": "^2.1.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11",
    "ts-utils": "^6.1.0",
    "victory": "^37.3.6",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@evilmartians/lefthook": "2.1.4",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "typescript": "5.9.3",
    "vite": "^8.0.0",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/exchange#readme",
  "license": "MIT",
  "main": "electron/main.js",
  "name": "exchange",
  "packageManager": "npm@11.9.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/exchange.git"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "deps:audit": "npm audit --audit-level=high",
    "deps:outdated": "npm outdated",
    "deps:unused": "knip",
    "dev": "vite",
    "electron:build": "tsc -p electron && electron-builder",
    "electron:build:linux": "tsc -p electron && electron-builder --linux",
    "electron:build:mac": "tsc -p electron && electron-builder --mac",
    "electron:build:win": "tsc -p electron && electron-builder --win",
    "electron:dev": "tsc -p electron && NODE_ENV=development electron .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "merge-locales": "node scripts/mergeLocales.js",
    "policy:all": "npm run policy:deps && npm run policy:flags",
    "policy:deps": "node scripts/checkDependencyAllowlist.js",
    "policy:flags": "node scripts/checkFeatureFlagPolicy.js",
    "prepare": "lefthook install",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --noEmit",
    "validate": "npm run policy:all && npm run deps:audit && npm run lint:check && npm run typecheck && npm run test && npm run build"
  },
  "type": "module",
  "version": "0.0.0"
}
