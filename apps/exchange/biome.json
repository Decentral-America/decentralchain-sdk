{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedKeys": "on"
      }
    },
    "enabled": true
  },
  "extends": "//",
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!dist", "!coverage", "!**/*.d.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "linter": {
    "domains": {
      "react": "recommended",
      "test": "recommended"
    },
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 25
          }
        }
      },
      "correctness": {
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "recommended": true,
      "security": {
        "noSecrets": {
          "level": "warn",
          "options": {
            "entropyThreshold": 72
          }
        }
      },
      "style": {
        "noCommonJs": "error",
        "noNamespace": "error",
        "noNonNullAssertion": "error",
        "useConst": "error",
        "useImportType": {
          "level": "error",
          "options": {
            "style": "inlineType"
          }
        }
      },
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["warn", "error"]
          }
        },
        "noControlCharactersInRegex": "off",
        "noExplicitAny": "error"
      }
    }
  },
  "overrides": [
    {
      "formatter": {
        "enabled": false
      },
      "includes": ["public/trading-view/**"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["test/**", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/components/ErrorBoundary.tsx",
        "src/components/GlobalKeyboardShortcuts.tsx",
        "src/components/PerformanceDashboard.tsx",
        "src/components/atoms/Tooltip.tsx",
        "src/components/charts/**",
        "src/components/display/QRCode.tsx",
        "src/components/landing/CoinsMarquee.tsx",
        "src/components/modals/AlertModal.tsx",
        "src/components/modals/ConfirmDialog.tsx",
        "src/components/notifications/TransactionNotificationsMonitor.tsx",
        "src/components/skeletons/PageSkeletons.tsx",
        "src/pages/ErrorPage.tsx",
        "**/*.stories.tsx",
        "**/*.stories.ts"
      ],
      "linter": {
        "rules": {
          "nursery": {
            "noInlineStyles": "off"
          }
        }
      }
    }
  ],
  "root": false,
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  }
}
