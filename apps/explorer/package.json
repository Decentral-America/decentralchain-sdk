{
  "name": "explorer",
  "version": "4.0.0",
  "type": "module",
  "private": true,
  "description": "DecentralChain blockchain explorer",
  "author": "DecentralChain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/explorer.git"
  },
  "homepage": "https://github.com/Decentral-America/explorer#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/explorer/issues"
  },
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --write .",
    "lint:fix": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "bulletproof": "npm run lint:fix && npm run test",
    "bulletproof:check": "npm run lint:check && npm run test",
    "prepare": "lefthook install",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run test && npm run build"
  },
  "dependencies": {
    "@decentralchain/node-api-js": "^2.0.1",
    "@decentralchain/ride-js": "^2.3.0",
    "@sentry/browser": "^10.5.0",
    "amplitude-js": "^8.21.9",
    "bignumber.js": "^9.1.2",
    "decimal.js": "10.6.0",
    "detect-browser": "^5.3.0",
    "dexie": "^4.2.0",
    "formik": "^2.4.6",
    "lodash": "^4.17.20",
    "prop-types": "15.8.1",
    "react": "19.2.4",
    "react-copy-to-clipboard-ts": "^1.3.0",
    "react-dom": "19.2.4",
    "react-ga4": "^2.1.0",
    "react-infinite-scroller": "^1.2.6",
    "react-modal": "3.16.3",
    "react-router": "7.13.1",
    "react-router-dom": "7.13.1",
    "react-scroll-up": "^1.4.0",
    "react-tooltip": "^5.29.1",
    "semver": "^7.7.2",
    "valid-url": "^1.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@decentralchain/ts-lib-crypto": "^2.0.1",
    "@evilmartians/lefthook": "2.1.3",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "sass": "^1.97.3",
    "vite": "^7.3.1",
    "vitest": "4.0.18"
  }
}
