{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "src",
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "preserveConstEnums": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2016"
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*"]
}
