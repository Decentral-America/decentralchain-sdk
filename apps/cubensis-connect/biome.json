{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedKeys": "on"
      }
    },
    "enabled": true
  },
  "css": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2
    },
    "linter": {
      "enabled": true
    }
  },
  "extends": "//",
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!dist", "!coverage", "!**/*.d.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "linter": {
    "domains": {
      "react": "recommended",
      "test": "recommended"
    },
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "off"
        }
      },
      "correctness": {
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "recommended": true,
      "security": {
        "noSecrets": "off"
      },
      "style": {
        "noCommonJs": "error",
        "noNamespace": "error",
        "noNonNullAssertion": "error",
        "useConst": "error",
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        }
      },
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["warn", "error"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["test/**", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/**", "postcss.config.cjs"],
      "linter": {
        "rules": {
          "style": {
            "noCommonJs": "off"
          },
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["src/assets/constants.ts", "src/constants.ts"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          }
        }
      }
    },
    {
      "includes": ["src/accounts/updateState.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/_core/spinner.tsx",
        "src/assets/assetSelect.tsx",
        "src/assets/selectModal.tsx",
        "src/nfts/nftCard.tsx",
        "src/nfts/nftList.tsx",
        "src/ui/components/ErrorBoundary.tsx",
        "src/ui/components/pages/assets/assetLogo.tsx",
        "src/ui/components/pages/assets/tabs/tabAssets.tsx",
        "src/ui/components/pages/assets/tabs/tabTxHistory.tsx",
        "src/ui/components/pages/swap/form.tsx",
        "src/ui/components/ui/Address/SuggestInput.tsx",
        "src/ui/components/ui/avatar/Avatar.tsx",
        "src/ui/components/ui/tooltip/index.tsx",
        "accounts.html",
        "notification.html",
        "popup.html"
      ],
      "linter": {
        "rules": {
          "nursery": {
            "noInlineStyles": "off"
          }
        }
      }
    }
  ],
  "root": false,
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  }
}
