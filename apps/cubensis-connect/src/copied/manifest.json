{
  "applications": {
    "gecko": {
      "id": "soporte@decentralchain.io"
    }
  },
  "author": "soporte@decentralchain.io",
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "chromeos": "Alt+Shift+K",
        "linux": "Alt+Shift+K",
        "mac": "Alt+Shift+K",
        "windows": "Alt+Shift+K"
      }
    }
  },
  "content_scripts": [
    {
      "all_frames": true,
      "js": ["contentscript.js"],
      "matches": ["http://*/*", "https://*/*"],
      "run_at": "document_end"
    }
  ],
  "description": "Cubensis Connect is your entry point to the DecentralChain blockchain and DCC-powered web services",
  "icons": {
    "16": "icons/icon_16.png",
    "24": "icons/icon_24.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "64": "icons/icon_64.png",
    "96": "icons/icon_96.png",
    "128": "icons/icon_128.png",
    "192": "icons/icon_192.png",
    "256": "icons/icon_256.png",
    "512": "icons/icon_512.png"
  },
  "manifest_version": null,
  "name": "Cubensis Connect",
  "permissions": ["alarms", "clipboardWrite", "idle", "storage", "unlimitedStorage", "tabs"],
  "short_name": "Cubensis",
  "version": null
}
