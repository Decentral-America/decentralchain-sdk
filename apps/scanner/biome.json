{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "css": {
    "formatter": { "enabled": false },
    "linter": { "enabled": false },
    "parser": {
      "tailwindDirectives": true
    }
  },
  "extends": "//",
  "files": {
    "ignoreUnknown": true,
    "includes": ["src/**/*.{ts,tsx}", "e2e/**/*.ts", "*.{ts,json}", "!test-results"],
    "maxSize": 1048576
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "domains": {
      "react": "recommended",
      "test": "recommended"
    },
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": "off"
      },
      "correctness": {
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "recommended": true,
      "security": {
        "noDangerouslySetInnerHtml": "error",
        "noGlobalEval": "error",
        "noSecrets": "off"
      },
      "style": {
        "useConst": "error",
        "useImportType": "error",
        "useTemplate": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "error",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["warn", "error"] }
        },
        "noDoubleEquals": "error",
        "noExplicitAny": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.d.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.*", "**/*.spec.*", "e2e/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["src/pages/TransactionMap.tsx"],
      "linter": {
        "rules": {
          "nursery": {
            "noInlineStyles": "off"
          }
        }
      }
    }
  ],
  "root": false,
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  }
}
