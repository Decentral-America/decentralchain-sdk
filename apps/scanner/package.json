{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@decentralchain/node-api-js": "workspace:*",
    "@react-router/node": "7.13.2",
    "@react-router/serve": "7.13.2",
    "@sentry/react": "^10.46.0",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "3.33.1",
    "cytoscape-fcose": "2.2.0",
    "isbot": "^5",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "description": "A modern, full-featured blockchain explorer for the DecentralChain (DCC) network. Explore blocks, transactions, addresses, assets, and network health in real time.",
  "devDependencies": {
    "@evilmartians/lefthook": "^2.1.4",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "7.13.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "catalog:",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/apps/scanner",
  "keywords": [
    "blockchain",
    "explorer",
    "decentralchain",
    "dcc",
    "cryptocurrency",
    "block-explorer",
    "react",
    "vite",
    "tailwindcss",
    "web3",
    "defi",
    "dex",
    "network-monitor"
  ],
  "license": "MIT",
  "name": "scanner",
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/build"
        ]
      },
      "test": {
        "inputs": [
          "default",
          "^production"
        ],
        "outputs": [
          "{projectRoot}/coverage"
        ]
      },
      "ci:check": {
        "cache": false,
        "dependsOn": [
          "build"
        ],
        "inputs": [
          "default",
          "^production"
        ]
      }
    },
    "tags": [
      "scope:app",
      "layer:5"
    ]
  },
  "private": true,
  "repository": {
    "directory": "apps/scanner",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "react-router build",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test:run",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test:run",
    "ci:check": "cd ../.. && bash scripts/run-with-required-node.sh pnpm nx run scanner:biome-lint --skip-nx-cache && bash scripts/run-with-required-node.sh pnpm nx run scanner:typecheck --skip-nx-cache && bash scripts/run-with-required-node.sh pnpm nx run scanner:test --skip-nx-cache && bash scripts/run-with-required-node.sh pnpm nx run scanner:build --skip-nx-cache && bash scripts/run-with-required-node.sh node apps/scanner/scripts/audit-scanner-deps.mjs",
    "dev": "react-router dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "lefthook install",
    "preview": "react-router-serve build/server/index.js",
    "start": "react-router-serve build/server/index.js",
    "test": "vitest run --coverage",
    "release:gate": "pnpm run ci:check",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run",
    "test:e2e": "playwright test",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "type": "module",
  "version": "1.0.0"
}
