{
  "author": "DecentralChain",
  "description": "DecentralChain SDK — Unified TypeScript monorepo for all @decentralchain packages",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nx/devkit": "22.6.3",
    "esbuild": "0.27.4",
    "knip": "6.1.0",
    "lefthook": "2.1.4",
    "nx": "22.6.3",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "license": "MIT",
  "name": "DecentralChain",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "brace-expansion": ">=5.0.5",
      "fast-xml-parser": ">=5.5.7",
      "path-to-regexp": ">=0.1.13",
      "picomatch": ">=4.0.4",
      "typescript": "$typescript",
      "yaml": ">=2.8.3",
      "yauzl": "^3.2.1"
    }
  },
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "graph": "nx graph",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "prepare": "lefthook install",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck --exclude=exchange,scanner"
  },
  "type": "module",
  "version": "0.0.0"
}
