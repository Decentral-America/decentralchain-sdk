{
  "name": "dcc-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "preview": "vite preview",
    "merge-locales": "node scripts/mergeLocales.js",
    "electron:dev": "tsc -p electron && NODE_ENV=development electron .",
    "electron:build": "tsc -p electron && electron-builder",
    "electron:build:mac": "tsc -p electron && electron-builder --mac",
    "electron:build:win": "tsc -p electron && electron-builder --win",
    "electron:build:linux": "tsc -p electron && electron-builder --linux"
  },
  "dependencies": {
    "@decentralchain/assets-pairs-order": "^4.0.0",
    "@decentralchain/marshall": "^0.14.0",
    "@decentralchain/signature-adapter": "^6.1.7",
    "@decentralchain/waves-transactions": "^4.2.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@ledgerhq/hw-transport-node-hid": "^6.29.14",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@sentry/react": "^10.20.0",
    "@sentry/tracing": "^7.120.4",
    "@tanstack/react-query": "^5.90.4",
    "@waves/bignumber": "^1.2.0",
    "@waves/data-entities": "^2.0.7",
    "@waves/data-service-client-js": "^4.1.1",
    "@waves/ledger": "^3.6.1",
    "@waves/oracle-data": "^0.0.6",
    "@waves/ts-lib-crypto": "^1.4.3",
    "@waves/waves-browser-bus": "^0.2.7",
    "axios": "^1.12.2",
    "classnames": "^2.5.1",
    "crypto-js": "^4.2.0",
    "cryptocurrency-icons": "^0.18.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lightweight-charts": "^5.0.9",
    "lodash-es": "^4.17.21",
    "qrcode.react": "^4.2.0",
    "ramda": "^0.32.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-ga4": "^2.1.0",
    "react-hook-form": "^7.65.0",
    "react-i18next": "^16.0.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.9.4",
    "styled-components": "^6.1.19",
    "ts-utils": "^6.1.0",
    "victory": "^37.3.6",
    "web-vitals": "^5.1.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^5.0.4",
    "charting_library": "^1.0.2",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "electron-updater": "^6.6.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7"
  },
  "build": {
    "appId": "com.decentralchain.wallet",
    "productName": "DCC Wallet",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "decentralchain",
      "repo": "dcc-wallet"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Finance"
    }
  }
}
