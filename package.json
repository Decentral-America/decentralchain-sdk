{
  "name": "@decentralchain/data-service-client-js",
  "version": "4.1.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Ivan Shmidt <bahoc47@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "build:browser:dev": "tsc && browserify ./dist/index.js -o ./dist/umd.js",
    "build:browser": "browserify ./dist/index.js -o ./dist/umd.js -u @decentralchain/data-entities -u @decentralchain/bignumber",
    "build:all": "rimraf ./dist/* && npm run build && npm run build:browser",
    "test": "jest",
    "prepare": "npm run build:all && npm test"
  },
  "dependencies": {
    "@decentralchain/bignumber": "^1.0.0",
    "@decentralchain/data-entities": "^2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "@types/node-fetch": "^2.6.0",
    "browserify": "^17.0.0",
    "jest": "^29.7.0",
    "node-fetch": "^2.7.0",
    "parse-json-bignumber": "^0.0.2",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testRegex": "(src/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".history"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    }
  }
}
