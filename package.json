{
  "author": "DecentralChain",
  "description": "DecentralChain SDK — Unified TypeScript monorepo for all @decentralchain packages",
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@nx/devkit": "22.5.4",
    "lefthook": "2.1.4",
    "nx": "22.5.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "license": "MIT",
  "name": "DecentralChain",
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.7",
      "typescript": "$typescript",
      "yauzl": "^3.2.1"
    }
  },
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "graph": "nx graph",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "prepare": "lefthook install",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck --exclude=cubensis-connect,exchange,scanner"
  },
  "type": "module",
  "version": "0.0.0"
}
