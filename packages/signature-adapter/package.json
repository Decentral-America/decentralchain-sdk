{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@decentralchain/bignumber": "workspace:*",
    "@decentralchain/data-entities": "workspace:*",
    "@decentralchain/ledger": "workspace:*",
    "@decentralchain/money-like-to-node": "workspace:*",
    "@decentralchain/transactions": "workspace:*",
    "@decentralchain/ts-types": "workspace:*"
  },
  "description": "Multi-provider transaction signing adapter for DecentralChain blockchain",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/signature-adapter",
  "keywords": [
    "decentralchain",
    "dcc",
    "signature",
    "adapter",
    "ledger",
    "transaction",
    "blockchain",
    "signing",
    "wallet"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/signature-adapter",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:4"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/signature-adapter",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "150 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "7.0.1"
}
