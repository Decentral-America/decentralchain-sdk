{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/assets-pairs-order/issues"
  },
  "dependencies": {
    "bs58": "^6.0.0"
  },
  "description": "Deterministic asset-pair ordering for the DecentralChain decentralized exchange (DEX). Resolves canonical amount/price asset direction using network priority lists.",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.7",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/assets-pairs-order#readme",
  "keywords": [
    "decentralchain",
    "dcc",
    "dex",
    "decentralized-exchange",
    "assets",
    "pairs",
    "order",
    "trading",
    "blockchain",
    "cryptocurrency",
    "matcher",
    "order-book",
    "asset-pair",
    "deterministic"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/assets-pairs-order",
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "packageManager": "npm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/assets-pairs-order.git"
  },
  "scripts": {
    "build": "tsdown",
    "build:browser": "tsdown",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "npm run build",
    "prepare": "lefthook install",
    "prepublishOnly": "npm run validate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run build && npm run typecheck && npm run test && npm run check:publint && npm run check:exports && npm run check:size"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "5 kB",
      "path": "./dist/index.global.js"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "5.0.2"
}
