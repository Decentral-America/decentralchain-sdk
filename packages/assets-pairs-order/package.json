{
  "name": "@decentralchain/assets-pairs-order",
  "version": "5.0.1",
  "description": "Deterministic asset-pair ordering for the DecentralChain decentralized exchange (DEX). Resolves canonical amount/price asset direction using network priority lists.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "src/",
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "author": "Decentral-America <https://github.com/Decentral-America>",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/assets-pairs-order.git"
  },
  "homepage": "https://github.com/Decentral-America/assets-pairs-order#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/assets-pairs-order/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.9.0",
  "keywords": [
    "decentralchain",
    "dcc",
    "dex",
    "decentralized-exchange",
    "assets",
    "pairs",
    "order",
    "trading",
    "blockchain",
    "cryptocurrency",
    "matcher",
    "order-book",
    "asset-pair",
    "deterministic"
  ],
  "scripts": {
    "build": "tsup",
    "build:browser": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:publint": "publint",
    "check:exports": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "check:size": "size-limit",
    "validate": "npm audit --audit-level=high && npm run format:check && npm run lint && npm run build && npm run typecheck && npm run test && npm run check:publint && npm run check:exports && npm run check:size",
    "bulletproof": "npm run format && npm run lint:fix && npm run build && npm run typecheck && npm run test",
    "bulletproof:check": "npm run format:check && npm run lint && npm run build && npm run typecheck && npm run test",
    "prepublishOnly": "npm run validate",
    "prepack": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "path": "./dist/index.global.js",
      "limit": "5 kB"
    }
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "bs58": "^6.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
