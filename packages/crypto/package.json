{
  "author": "DecentralChain <https://github.com/Decentral-America>",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0"
  },
  "description": "Async WASM cryptographic library for DecentralChain — Ed25519/X25519 key generation, signing, AES encryption, seed management",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "rimraf": "^6.0.1",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.spec.*",
    "pkg",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/crypto",
  "keywords": [
    "decentralchain",
    "crypto",
    "wasm",
    "ed25519",
    "x25519",
    "aes",
    "encryption",
    "signing",
    "blockchain",
    "wallet"
  ],
  "license": "MIT",
  "module": "./dist/index.js",
  "name": "@decentralchain/crypto",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:0"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/crypto",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "npm run build:wasm && npm run build:ts",
    "build:ts": "tsc",
    "build:wasm": "wasm-pack build --target web --release && rimraf pkg/package.json pkg/.gitignore",
    "check:exports": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "check:publint": "publint",
    "dev:wasm": "wasm-pack build --target web --dev && rimraf pkg/package.json pkg/.gitignore",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "1.0.2"
}
