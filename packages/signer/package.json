{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "@decentralchain/node-api-js": "workspace:*",
    "@decentralchain/ts-lib-crypto": "workspace:*",
    "@decentralchain/ts-types": "workspace:*"
  },
  "description": "Official DecentralChain transaction signing orchestrator — securely connect any provider to sign and broadcast blockchain transactions without exposing private keys",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@decentralchain/transactions": "workspace:*",
    "@size-limit/preset-small-lib": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "typed-ts-events": "^3.0.1",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/signer",
  "keywords": [
    "decentralchain",
    "dcc",
    "signer",
    "blockchain",
    "transactions",
    "provider",
    "wallet",
    "dapp",
    "web3",
    "crypto",
    "digital-assets",
    "smart-contracts",
    "decentralized",
    "sdk"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "name": "@decentralchain/signer",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:3"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/signer",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "55 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.0.1"
}
