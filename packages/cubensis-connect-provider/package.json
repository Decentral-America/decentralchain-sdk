{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "@decentralchain/cubensis-connect-types": "workspace:*",
    "@decentralchain/marshall": "workspace:*",
    "typed-ts-events": "^3.0.1"
  },
  "description": "CubensisConnect provider for DCC Signer — browser wallet integration for DecentralChain",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@decentralchain/signer": "workspace:*",
    "@size-limit/preset-small-lib": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/cubensis-connect-provider",
  "keywords": [
    "decentralchain",
    "dcc",
    "signer",
    "provider",
    "cubensis-connect",
    "blockchain",
    "wallet"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/cubensis-connect-provider",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:4"
    ]
  },
  "peerDependencies": {
    "@decentralchain/signer": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/cubensis-connect-provider",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "import": "{ ProviderCubensis }",
      "limit": "15 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "1.0.1"
}
