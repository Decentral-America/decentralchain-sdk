{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/cubensis-connect-types/issues"
  },
  "description": "TypeScript type definitions for the CubensisConnect browser-extension API",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/cubensis-connect-types#readme",
  "keywords": [
    "types",
    "typescript",
    "cubensisconnect",
    "decentralchain",
    "blockchain",
    "browser-extension"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/cubensis-connect-types",
  "packageManager": "npm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/cubensis-connect-types.git"
  },
  "scripts": {
    "build": "tsdown",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "npm run bulletproof:check && npm run build && npm run check:publint && npm run check:exports && npm run check:size"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "1 kB",
      "path": "dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "1.0.0"
}
