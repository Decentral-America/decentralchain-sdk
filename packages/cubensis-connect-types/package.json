{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "description": "TypeScript type definitions for the CubensisConnect browser-extension API",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/cubensis-connect-types",
  "keywords": [
    "types",
    "typescript",
    "cubensisconnect",
    "decentralchain",
    "blockchain",
    "browser-extension"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/cubensis-connect-types",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:0"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/cubensis-connect-types",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "1 kB",
      "path": "dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "1.0.1"
}
