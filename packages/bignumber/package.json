{
  "name": "@decentralchain/bignumber",
  "version": "1.1.1",
  "description": "Official arbitrary-precision BigNumber library for the DecentralChain blockchain SDK — safe arithmetic and byte serialization for token amounts, transaction fees, and on-chain financial computations",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/bignumber.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "bugs": {
    "url": "https://github.com/Decentral-America/bignumber/issues"
  },
  "homepage": "https://github.com/Decentral-America/bignumber#readme",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "validate": "npm audit --audit-level=high && npm run bulletproof:check && npm run build && publint && attw --pack --ignore-rules cjs-resolves-to-esm && size-limit",
    "prepublishOnly": "npm run validate",
    "prepare": "lefthook install"
  },
  "size-limit": [
    {
      "path": "./dist/index.mjs",
      "limit": "10 kB",
      "import": "{ BigNumber }"
    }
  ],
  "keywords": [
    "bignumber",
    "bigint",
    "arbitrary-precision",
    "blockchain",
    "decentralchain",
    "sdk",
    "math",
    "decimal",
    "defi",
    "cryptocurrency",
    "token",
    "transaction",
    "serialization",
    "financial",
    "precision"
  ],
  "author": "DecentralChain",
  "license": "MIT",
  "dependencies": {
    "bignumber.js": "^10.0.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@evilmartians/lefthook": "1.11.13",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "long": "^5.3.2",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
