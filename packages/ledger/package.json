{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "@ledgerhq/logs": "6.14.0"
  },
  "description": "DecentralChain Ledger hardware wallet integration library",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/ledger",
  "keywords": [
    "decentralchain",
    "dcc",
    "ledger",
    "hardware-wallet",
    "signing",
    "nano-s",
    "nano-x",
    "webusb"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/ledger",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:0"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/ledger",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "import": "{ DCCLedger }",
      "limit": "10 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "5.1.1"
}
