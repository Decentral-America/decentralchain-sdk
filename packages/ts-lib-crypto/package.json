{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@noble/ciphers": "2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1"
  },
  "description": "Official TypeScript cryptographic library for the DecentralChain blockchain — key generation, digital signatures, hashing, encoding, and encryption primitives for building secure dApps and protocol integrations.",
  "devDependencies": {
    "@decentralchain/crypto": "workspace:*",
    "@arethetypeswrong/cli": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "fast-check": "4.6.0",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./bytes": {
      "types": "./dist/bytes.d.mts",
      "default": "./dist/bytes.mjs"
    },
    "./rsa": {
      "types": "./dist/rsa.d.mts",
      "default": "./dist/rsa.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/ts-lib-crypto",
  "keywords": [
    "decentralchain",
    "dcc",
    "blockchain",
    "crypto",
    "cryptography",
    "protocol",
    "binary",
    "signature",
    "digital-signature",
    "wallet",
    "hashing",
    "encryption",
    "blake2b",
    "keccak",
    "sha256",
    "aes",
    "rsa",
    "bls12-381",
    "base58",
    "ed25519",
    "curve25519",
    "mnemonic",
    "seed-phrase",
    "key-generation",
    "typescript"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/ts-lib-crypto",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:0"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/ts-lib-crypto",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.0.1"
}
