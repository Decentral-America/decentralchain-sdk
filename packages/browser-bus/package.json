{
  "name": "@decentralchain/browser-bus",
  "version": "1.0.0",
  "description": "Cross-window browser communication library for DecentralChain DApps and wallet applications",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/browser-bus.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/browser-bus#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/browser-bus/issues"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:publint": "publint",
    "check:exports": "attw --pack . --ignore-rules no-resolution",
    "check:size": "size-limit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "prepare": "lefthook install",
    "prepack": "npm run build",
    "postversion": "npm publish",
    "postpublish": "git push",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "size-limit": [
    {
      "path": "./dist/index.mjs",
      "limit": "10 kB"
    }
  ],
  "keywords": [
    "decentralchain",
    "dcc",
    "browser-bus",
    "postMessage",
    "cross-window",
    "communication",
    "dapp",
    "wallet"
  ],
  "author": "DecentralChain",
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "28.1.0",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "ts-utils": "6.1.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
